# Environment file for CVE Daily

# Optional: Proxy used by crawlers (helps when target sites block requests from your network)
# The code prefers HTTPS_PROXY and falls back to HTTP_PROXY; either may be set.
# Leave both commented out to use a direct connection.
# HTTPS_PROXY=http://127.0.0.1:10808
# HTTP_PROXY=http://127.0.0.1:10808

# AI Curation (supports OpenAI-compatible APIs)
# Requires AI_API_KEY to be configured
# AI_API_KEY=sk-your_api_key_here
# AI_MODEL=glm-4
# AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
